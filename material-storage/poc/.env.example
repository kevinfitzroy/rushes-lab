# material-storage PoC 环境变量模板(v0.5)
# 用法:cp .env.example .env;然后 vim .env 填入真实值。**绝不**提交 .env(.gitignore 已覆盖)。
#
# 端口策略(v0.5 F-6)— 默认搬到 6000-7000 区间,适配阿里云 ECS 默认安全组
# 若你的部署机端口策略不同,可改 SEAFILE_PORT / MINIO_CONSOLE_PORT 等;
# MinIO S3 API 端口默认不外暴露(docker-compose.yml 已删 host 映射,仅 docker network 内访问)

# ────── 公共 ──────
# PoC 数据根目录;dataset-gen 输出 + 容器 volumes 都在此下面分子目录
DATA_ROOT=/srv/poc-data

# ────── Seafile Pro + 本地 MinIO(seafile/docker-compose.yml 用,v0.5 唯一主线)──────
SEAFILE_DB_PASSWORD=<请填强随机>
SEAFILE_ADMIN_EMAIL=admin@example.com
SEAFILE_ADMIN_PASSWORD=<请填强随机>
SEAFILE_HOST=poc.example.com            # 或 IP
SEAFILE_PORT=6083                       # F-6:6000-7000 区间(原 8083 可能不在云安全组)

# MinIO 作 Seafile 的 S3 backend(Seafile Pro 必需,CE 不支持 — 见 F-X)
MINIO_ROOT_USER=<填强随机 access key,生产用 mc admin user 建独立用户>
MINIO_ROOT_PASSWORD=<填强随机 secret key>
MINIO_API_PORT=9000                     # 仅 docker network 内,不外暴露
MINIO_CONSOLE_PORT=6901                 # F-6:Console 走 6901(管理员经 SSH 隧道或直接访问)
MINIO_DATA_DIR=${DATA_ROOT}/minio       # MinIO 实际数据落盘位置(对应 ZFS dataset A)
MINIO_WEBHOOK_ENDPOINT=http://host.docker.internal:8090/   # FastAPI 旁路 endpoint;PoC 早期可指 echo server

# ────── Nextcloud(v0.5 退出 PoC,变量保留作历史参考,不在首批 PoC 启用)──────
# 详见 file-management-system.md §11 v0.5 调整 + ADR-0003 §6
# NC_DB_NAME=nextcloud
# NC_DB_USER=nextcloud
# NC_DB_PASSWORD=<请填强随机>
# NC_ADMIN_USER=admin
# NC_ADMIN_PASSWORD=<请填强随机>
# NC_HOST=poc.example.com
# NC_PROTOCOL=http
# NC_TRUSTED_DOMAINS=poc.example.com localhost 127.0.0.1
# NC_PORT=6080
# NC_DATA_DIR=${DATA_ROOT}/nc-data

# ────── oCIS(ocis/docker-compose.yml 用,v0.5 P1 长期方向 / Pro license 应急路径)──────
# v0.5 首批 PoC 不跑;ADR-0003 §License 应急路径若 Pro 不可获取则 promote Issue #13 到 P0
OCIS_URL=http://poc.example.com:6082
OCIS_OIDC_ISSUER=https://rusheslab.taoxiplan.com/oidc
OCIS_OIDC_CLIENT_ID=ocis-poc
OCIS_OIDC_CLIENT_SECRET=<飞书 bridge 静态配置中的 client_secret>
OCIS_PORT=6082
OCIS_DATA_DIR=${DATA_ROOT}/ocis-data
