# material-storage PoC 环境变量模板
# 用法:cp .env.example .env;然后 vim .env 填入真实值。**绝不**提交 .env(.gitignore 已覆盖)。

# ────── 公共 ──────
# PoC 数据根目录;dataset-gen 输出 + 容器 volumes 都在此下面分子目录
DATA_ROOT=/srv/poc-data

# ────── Nextcloud(nc/docker-compose.yml 用)──────
NC_DB_NAME=nextcloud
NC_DB_USER=nextcloud
NC_DB_PASSWORD=<请填强随机>
NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=<请填强随机>
NC_HOST=poc.example.com               # 或 IP,生产换业务域名
NC_PROTOCOL=http                       # PoC 走 http;生产走 https
NC_TRUSTED_DOMAINS=poc.example.com localhost 127.0.0.1
NC_PORT=8081
NC_DATA_DIR=${DATA_ROOT}/nc-data       # NC datadirectory(挂到 ZFS dataset 上)

# ────── oCIS(ocis/docker-compose.yml 用)──────
OCIS_URL=http://poc.example.com:8082
OCIS_OIDC_ISSUER=https://rusheslab.taoxiplan.com/oidc    # 飞书 bridge 提供;PoC 期间使用
OCIS_OIDC_CLIENT_ID=ocis-poc
OCIS_OIDC_CLIENT_SECRET=<飞书 bridge 静态配置中的 client_secret>
OCIS_PORT=8082
OCIS_DATA_DIR=${DATA_ROOT}/ocis-data
