# material-storage-api .env example
# 拷贝为 .env 并填实际值(.env 已 gitignore)

ENV=dev
LOG_LEVEL=INFO
LOG_FORMAT=console

# ─── Postgres(业务元数据 + audit;OpenFGA 共 instance 不同 db)──────
DB_URL=postgresql+asyncpg://msuser:mspass@localhost:5432/material_storage

# ─── Redis(arq queue + session cache)──────
REDIS_URL=redis://localhost:6379/0

# ─── MinIO ────────────────────────────────
MINIO_ENDPOINT_INTERNAL=http://poc-pigsty-minio:9000
MINIO_ENDPOINT_PUBLIC=https://rusheslab.taoxiplan.com
MINIO_ACCESS_KEY=alice
MINIO_SECRET_KEY=alicesecret-poc-2026-32chars-pad
MINIO_DEFAULT_BUCKET=incoming

# ─── OpenFGA ──────────────────────────────
OPENFGA_API_URL=http://poc-openfga:8080
OPENFGA_STORE_ID=01KRR4FJN1S3RS112BZPN3ZXRH
# OPENFGA_MODEL_ID=...        # 可选;None = 用 store latest

# ─── 飞书 OIDC(iter5)────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=...           # see ../../../server.md (LOCAL ONLY)
# 飞书 passport.feishu.cn 标准 OAuth2;以下三个 endpoint 通常无需改:
# FEISHU_AUTHORIZE_ENDPOINT=https://passport.feishu.cn/suite/passport/oauth/authorize
# FEISHU_TOKEN_ENDPOINT=https://passport.feishu.cn/suite/passport/oauth/token
# FEISHU_USERINFO_ENDPOINT=https://passport.feishu.cn/suite/passport/oauth/userinfo
# FEISHU_OIDC_SCOPE=contact:user.base:readonly
FEISHU_REDIRECT_URI=https://rusheslab.taoxiplan.com/api/v1/auth/callback

# ─── session JWT(iter5;openssl rand -hex 32 生成)───
SESSION_JWT_SECRET=replace-me-with-32-byte-random-hex-string
# SESSION_JWT_ALG=HS256
# SESSION_JWT_TTL_SECONDS=86400
# SESSION_COOKIE_NAME=ms_session
# SESSION_COOKIE_SECURE=true       # dev 本地 http 时设 false
# SESSION_COOKIE_SAMESITE=lax

# ─── presigned URL TTL ────────────────────
PRESIGNED_NORMAL_TTL_SECONDS=900
PRESIGNED_SENSITIVE_TTL_SECONDS=600

# ─── audit ────────────────────────────────
AUDIT_RETENTION_DAYS=365
