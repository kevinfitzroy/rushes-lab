# feishu-integration env. 部署时复制为 .env 并填真值;.env 不进 git。

# 必填:飞书开发者后台 → 应用凭证
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=

# 必填:飞书开发者后台 → 事件订阅 → 加密策略
FEISHU_VERIFICATION_TOKEN=

# 选填:启用 Encrypt Key 时必填;留空则 bridge 期望明文回调
FEISHU_ENCRYPT_KEY=

# === 以下契约 v1 实施时才用到的变量,PoC 阶段可空 ===

# 上游(material-storage)调 bridge 用的共享 token
BRIDGE_TOKEN=

# bridge → upstream webhook 推送的目标 URL 与 HMAC 密钥
WEBHOOK_TARGET_URL=
WEBHOOK_SIGNING_SECRET=
